# Shelly Pro EM-50
SHELLY_HOST=192.168.1.6
SHELLY_POLL_INTERVAL_MS=5000
SHELLY_TIMEOUT_MS=3000

# MQTT — set SHELLY_MQTT_PREFIX to enable MQTT mode (preferred over HTTP polling).
# First run: SHELLY_HOST=192.168.1.6 BROKER_HOST=<your-host-ip> bun scripts/configure-shelly-mqtt.ts
# Then set the prefix below (must match the value used in the script).
SHELLY_MQTT_PREFIX=
# MQTT_BROKER_URL is set automatically in docker-compose (mqtt://mosquitto:1883)

# TimescaleDB
DATABASE_URL=postgres://gridsense:gridsense@localhost:5432/gridsense

# Redis
REDIS_URL=redis://localhost:6379

# Collector internal API
COLLECTOR_PORT=3001

# Main API
API_PORT=3000

# On Linux Docker: set to "host" so containers reach 192.168.x.x
# On macOS/Windows Docker Desktop: leave as "bridge"
COLLECTOR_NETWORK_MODE=bridge

# AI Assistant — get your key at https://console.anthropic.com
# Leave empty to disable the AI chat panel on the dashboard.
ANTHROPIC_API_KEY=
