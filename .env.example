# Shelly Pro EM-50
SHELLY_HOST=192.168.1.6
SHELLY_POLL_INTERVAL_MS=5000
SHELLY_TIMEOUT_MS=3000

# TimescaleDB
DATABASE_URL=postgres://gridsense:gridsense@localhost:5432/gridsense

# Collector internal API
COLLECTOR_PORT=3001

# Main API
API_PORT=3000

# On Linux Docker: set to "host" so containers reach 192.168.x.x
# On macOS/Windows Docker Desktop: leave as "bridge"
COLLECTOR_NETWORK_MODE=bridge
